# ============================================
# OmniSeed Configuration
# ============================================
# Copy this file to .env and fill in the values.

# --- Target Database ---
# Supported types: postgres, sqlite, mysql
# Examples:
#   PostgreSQL: postgresql://user:pass@localhost:5432/my_app_db
#   SQLite:     sqlite:///path/to/database.db
#   MySQL:      mysql://user:pass@localhost:3306/my_app_db
DB_CONNECTION_STRING=postgresql://user:pass@localhost:5432/my_app_db

# --- AI Integration ---
# Supported providers: openai, anthropic, gemini
LLM_PROVIDER=openai
LLM_API_KEY=sk-proj-your-api-key-here
LLM_MODEL=gpt-4o

# --- Generation Context ---
# Language for generated data (e.g., tr, en, de, fr)
SEED_LANGUAGE=tr

# Describe your application domain so the AI generates contextually relevant data
SYSTEM_CONTEXT="This is an online bookstore. Generate realistic Turkish book titles, authors, and prices. Ensure cover image URLs use placeholder services like picsum.photos."

# Number of rows to generate per table
ROW_COUNT_PER_TABLE=10
